generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  adminId   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  admin     User     @relation("ShopAdmin", fields: [adminId], references: [id])
  users     User[]   @relation("ShopUsers")
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String
  name        String
  role        Role      @default(EMPLOYEE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isActive    Boolean   @default(true)
  lastLogin   DateTime?
  shopId      String?
  orders      Order[]
  sessions    Session[]
  managedShop Shop?     @relation("ShopAdmin")
  shop        Shop?     @relation("ShopUsers", fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([role])
}

model Terminal {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
}

model Session {
  id          String        @id @default(uuid())
  terminalId  String
  userId      String
  startAt     DateTime      @default(now())
  endAt       DateTime?
  status      SessionStatus @default(OPEN)
  openingCash Decimal       @default(0) @db.Decimal(10, 2)
  closingCash Decimal?      @db.Decimal(10, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  orders      Order[]
  terminal    Terminal      @relation(fields: [terminalId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
}

model Floor {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tables    Table[]
}

model Table {
  id        String   @id @default(uuid())
  name      String
  seats     Int
  active    Boolean  @default(true)
  floorId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    String   @default("AVAILABLE")
  orders    Order[]
  floor     Floor    @relation(fields: [floorId], references: [id])

  @@index([floorId])
}

model Category {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id            String      @id @default(uuid())
  name          String
  description   String?
  price         Decimal     @db.Decimal(10, 2)
  unit          String?
  tax           Decimal     @default(0) @db.Decimal(5, 2)
  isAvailable   Boolean     @default(true)
  sendToKitchen Boolean     @default(false)
  categoryId    String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  imageUrl      String?
  orderItems        OrderItem[]
  category          Category    @relation(fields: [categoryId], references: [id])
  variants          Variant[]
  promotionProducts PromotionProduct[]

  @@index([categoryId])
}

model Variant {
  id         String      @id @default(uuid())
  name       String
  extraPrice Decimal     @default(0) @db.Decimal(10, 2)
  productId  String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id])

  @@index([productId])
}

model Order {
  id             String         @id @default(uuid())
  orderNumber    String         @unique
  status         OrderStatus    @default(DRAFT)
  type           String         @default("DINE_IN")
  version        Int            @default(1)
  sessionId      String?
  tableId        String?
  userId         String?
  customerName   String?
  customerEmail  String?
  customerMobile String?
  totalAmount    Decimal        @default(0) @db.Decimal(10, 2)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  discountAmount Decimal        @default(0) @db.Decimal(10, 2)
  discountCode   String?
  taxAmount      Decimal        @default(0) @db.Decimal(10, 2)
  paymentStatus  String         @default("PENDING")
  kitchenTicket  KitchenTicket?
  session        Session?       @relation(fields: [sessionId], references: [id])
  table          Table?         @relation(fields: [tableId], references: [id])
  user              User?          @relation(fields: [userId], references: [id])
  items             OrderItem[]
  payments          Payment[]
  appliedPromotions Json?

  @@index([createdAt])
  @@index([customerEmail])
  @@index([customerMobile])
  @@index([paymentStatus])
  @@index([sessionId])
  @@index([status])
  @@index([tableId])
  @@index([userId])
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  productId   String
  productName String
  price       Decimal  @db.Decimal(10, 2)
  variantName String?
  variantId   String?
  quantity    Int
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  notes       String?
  order       Order    @relation(fields: [orderId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
  variant     Variant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model Payment {
  id        String        @id @default(uuid())
  orderId   String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(10, 2)
  status    PaymentStatus @default(PENDING)
  reference String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  order     Order         @relation(fields: [orderId], references: [id])

  @@index([createdAt])
  @@index([orderId])
  @@index([status])
}

model Settings {
  id             String   @id @default(uuid())
  cafeName       String   @default("Odoo Cafe")
  receiptFooter  String   @default("Thank you for your visit!")
  currency       String   @default("₹")
  cashEnabled    Boolean  @default(true)
  digitalEnabled Boolean  @default(true)
  upiEnabled     Boolean  @default(true)
  upiId          String?
  updatedAt      DateTime @updatedAt
}

model Coupon {
  id        String    @id @default(uuid())
  code      String    @unique
  discount  Decimal   @db.Decimal(10, 2)
  type      String    @default("PERCENTAGE")
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model KitchenTicket {
  id        String   @id @default(uuid())
  orderId   String   @unique
  status    String   @default("TO_COOK")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  EMPLOYEE
  KITCHEN
}

enum OrderStatus {
  DRAFT
  SENT
  PREPARING
  COMPLETED
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  DIGITAL
  UPI
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum SessionStatus {
  OPEN
  CLOSED
}

model Promotion {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String   // 'COUPON', 'PRODUCT_DISCOUNT', 'BUY_X_GET_Y', 'COMBO', 'ORDER_VALUE'
  isActive    Boolean  @default(true)
  startDate   DateTime @default(now())
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  couponCode  CouponCode?
  products    PromotionProduct[]
  conditions  PromotionCondition[]
  rewards     PromotionReward[]

  @@map("promotions")
}

model CouponCode {
  id          String   @id @default(uuid())
  promotionId String   @unique
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@map("coupon_codes")
}

model PromotionProduct {
  id          String   @id @default(uuid())
  promotionId String
  productId   String
  role        String   // 'TRIGGER', 'REWARD', 'DISCOUNTED', 'COMBO_ITEM'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([promotionId])
  @@index([productId])
  @@map("promotion_products")
}

model PromotionCondition {
  id               String   @id @default(uuid())
  promotionId      String
  minOrderAmount   Decimal? @db.Decimal(10, 2)
  triggerProductId String?
  triggerQuantity  Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  promotion        Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([promotionId])
  @@map("promotion_conditions")
}

model PromotionReward {
  id              String   @id @default(uuid())
  promotionId     String
  rewardProductId String?
  rewardQuantity  Int?
  discountType    String?  // 'PERCENTAGE', 'FIXED'
  discountValue   Decimal? @db.Decimal(10, 2)
  comboPrice      Decimal? @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  promotion       Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([promotionId])
  @@map("promotion_rewards")
}

model PromotionTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  type        String   // 'COUPON', 'PRODUCT_DISCOUNT', 'BUY_X_GET_Y', 'COMBO', 'ORDER_VALUE'
  configJson  String   // JSON configuration containing template parameters
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("promotion_templates")
}
